#!/bin/bash
set -e

# Install metakernel with all extras and local kernels
pip install ".[activity,parallel]" ./metakernel_python ./metakernel_echo

# Install Processing 4
PROCESSING_VERSION="4.5.2"
PROCESSING_DIR="${HOME}/processing"
curl -fsSL "https://github.com/processing/processing4/releases/download/processing-1313-${PROCESSING_VERSION}/processing-${PROCESSING_VERSION}-linux-x64-portable.zip" -o /tmp/processing.zip
unzip -q /tmp/processing.zip -d "${HOME}"
mv "${HOME}/Processing" "${PROCESSING_DIR}"
rm /tmp/processing.zip
ln -s "${PROCESSING_DIR}/bin/Processing" "$(dirname $(which python))/processing-java"

# Install calysto_processing kernel spec
python -m calysto_processing install --user

# Remove SAS example notebook
rm -f examples/SAS_metakernel_example.ipynb

# Clean up pip cache
pip cache purge

# Clean up conda cache
conda clean --all --yes
